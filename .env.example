# MacJit Backend Environment Variables

# Database Configuration
MONGO_URL=mongodb+srv://your-connection-string
DB_NAME=macjit

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-secure-jwt-secret-here

# Admin User Seeding (DISABLED by default for security)
# Set SEED_ADMIN=true to enable automatic admin creation
# SEED_ADMIN=true
# ADMIN_USERNAME=your-admin-username
# ADMIN_PASSWORD=your-secure-admin-password
# ADMIN_NAME=Your Admin Name
# ADMIN_PHONE=+919876543210

# Encryption Key (generate a strong random key for production)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Optional: External Services
# KAFKA_BOOTSTRAP=your-kafka-bootstrap-server
# KAFKA_API_KEY=your-kafka-api-key
# KAFKA_API_SECRET=your-kafka-api-secret
# RABBITMQ_URL=your-rabbitmq-url
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
# RAZORPAY_KEY_ID=your-razorpay-key
# RAZORPAY_KEY_SECRET=your-razorpay-secret

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com