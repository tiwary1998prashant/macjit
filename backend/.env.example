# MacJit Backend — copy this to .env.local / .env.dev / .env.prod and fill in values
# Set ENVIRONMENT=local | dev | prod  (the config.py picks .env.<value>)

ENVIRONMENT=local

# ── Database ──
MONGO_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net
DB_NAME=macjit

# ── Security ──
JWT_SECRET=change-this-to-a-long-random-string
ENCRYPTION_KEY=change-this-to-a-32-char-string

# ── Razorpay (leave blank to disable) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Twilio WhatsApp / SMS (leave blank to disable) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# ── App ──
PUBLIC_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
